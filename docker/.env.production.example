#
# WKS Platform — single-tenant production .env template (Story 14.1).
#
# Usage:
#   cp docker/.env.production.example docker/.env
#   # fill in values (generate secrets with: openssl rand -base64 32)
#   docker compose -f docker/docker-compose.prod.yml up
#
# This file MUST NOT contain `tenant_id`, `tenantId`, or any client-scoping field
# intended for application code. Per Decision 25, customer identity lives in the
# license file (Decision 24, Epic 7), not in domain rows.
#
# Sibling surface: deploy/templates/client.env.template (Story 14.7) is the
# per-client deployment shape; this file is the single-tenant production
# reference. They share the same env-var contract for the WKS application.
#
# IRREVERSIBILITY WARNING: `docker compose -f docker/docker-compose.prod.yml down -v`
# DELETES the Postgres + MinIO data volumes (wks-pgdata, wks-miniodata).
# This IS the GDPR-delete path — there is NO recovery. Use plain `down`
# (no -v) if you intend to restart later with data preserved.
#
# SECRETS — every value below set to `<MUST-BE-ROTATED>` (Story 14.1.1 AC7) is
# a sentinel: the application boot-time validator rejects it under the
# production profile and fails closed with WKS-API-055. Replace each with a
# real secret BEFORE bringing the stack up. Generate with:
#   openssl rand -base64 32   (or 48 for JWT signing)

# ----- WKS application config (consumed by application-production.yml) -----

# Postgres datasource — Spring fails fast at startup if WKS_DB_URL is unset.
WKS_DB_URL=jdbc:postgresql://postgres:5432/wks
WKS_DB_USER=wks
WKS_DB_PASSWORD=<MUST-BE-ROTATED>

# MinIO endpoint (single-key static-credentials pattern, Decision 8 §437).
# Q5 (Sprint 3 locked 2026-05-06): single WKS_STORAGE_KEY preserves Story 14.7's
# already-shipped wire contract. The bundled MinIO container's root user is
# the username; this key is the secret.
WKS_STORAGE_ENDPOINT=http://minio:9000
WKS_STORAGE_KEY=<MUST-BE-ROTATED>

# First-boot admin (Story 1.2 cookie-JWT auth). WKS-API-051 fails closed in
# production if either is empty; WKS-API-055 fails closed if either equals
# the `<MUST-BE-ROTATED>` sentinel.
WKS_ADMIN_EMAIL=<MUST-BE-ROTATED>
WKS_ADMIN_PASSWORD=<MUST-BE-ROTATED>

# Locale + CORS. WKS_LOCALE defaults to en-IN if unset (application-production.yml).
WKS_LOCALE=en-IN
WKS_CORS_ORIGINS=

# JWT signing secret (Base64-encoded random, ≥32 bytes). Generate with:
#   openssl rand -base64 48
# WKS-API-053 fails closed if missing / invalid Base64 / too short.
# WKS-API-055 fails closed if equal to the `<MUST-BE-ROTATED>` sentinel.
WKS_JWT_SECRET=<MUST-BE-ROTATED>

# OpenAPI / Swagger UI — default false in production (recurring CVE vector
# when /v3/api-docs is unauthenticated). Set true to enable.
WKS_OPENAPI_ENABLED=false

# Keycloak/SSO seam — RESERVED forward-compat seam for Story 10.4. Setting
# this to `true` today logs a WARN at boot (WKS-AUTH-001) and changes NOTHING
# about auth enforcement. Built-in cookie-JWT (Story 1.2) is the sole auth
# gate until Story 10.4 ships. (Story 14.1.1 AC4 wording.)
WKS_KEYCLOAK_ENABLED=false

# ----- Compose-only keys (provision the bundled containers) -----

# MinIO root credentials — the WKS application does NOT read these directly;
# they configure the bundled MinIO container. WKS_STORAGE_KEY (above) is what
# the application consumes. WKS-API-055 fails closed if either equals
# `<MUST-BE-ROTATED>` (Story 14.1.1 AC7 — the `minioadmin` default would have
# silently shipped to production otherwise).
WKS_MINIO_ROOT_USER=<MUST-BE-ROTATED>
WKS_MINIO_ROOT_PASSWORD=<MUST-BE-ROTATED>

# Optional host port mapping for the WKS app (default 8080).
WKS_HOST_PORT=8080

# Optional Keycloak admin (only used when stacking docker-compose.sso.yml on top
# of docker-compose.prod.yml). The `admin`/`admin` defaults are NOT shipped —
# operators must rotate before bringing up the SSO seam.
WKS_KEYCLOAK_ADMIN=<MUST-BE-ROTATED>
WKS_KEYCLOAK_ADMIN_PASSWORD=<MUST-BE-ROTATED>
WKS_KEYCLOAK_PORT=8081
