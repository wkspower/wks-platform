## ============================================================================
## WKS Platform — LOCAL DEVELOPMENT configuration.
## Copy to .env (`cp .env-sample .env`) and adjust as needed.
## This configures the local docker-compose.yml stack only — not production.
## ============================================================================

## Image source (app images are pulled from GHCR by default; `--build` ignores these)
WKS_REGISTRY=ghcr.io/wkspower
WKS_VERSION=v1.4.14

## Which profiles start with a bare `docker compose up`.
## Default = the FULL stack: all infra (mongodb, keycloak, opa, camunda, storage)
## + the full case-engine (profile `full`) + portal + demo seed, so the app is
## login-ready out of the box (the demo loader creates the Keycloak realm/users
## + sample cases).
##   COMPOSE_PROFILES=core   -> MINIMAL: zero-dependency backend only (embedded H2
##                              + dev-token, no Mongo/Keycloak/OPA/Camunda/MinIO).
##                              Build from source (--build) and run the portal via
##                              `yarn start` with REACT_APP_AUTH_MODE=dev-token.
## Optional add-ons: notifications, proxy.
##   COMPOSE_PROFILES=storage-fs -> MinIO-free storage (local-disk + dev-token,
##                                  self-contained). Build from source (--build).
## NOTE: `core`/`full` both bind 8081; `storage`/`storage-fs` both bind 8085 —
##       never enable both of a pair together.
COMPOSE_PROFILES=mongodb,keycloak,opa,camunda,storage,full,portal,demo

## Workflow engine selector for case-engine-rest-api (camunda7 is the supported engine)
CAMUNDA_VERSION=camunda7

## Toggle Kafka publishing on the engine side. Turn on together with the
## `notifications` profile to exercise email / websocket / novu events.
KAFKA_ENABLED=false

## Database
MONGO_CONNECTION_URL=mongodb://mongodb
MONGO_WKS_DATABASE=wks

## Demo Data loader
MONGO_DEMO_DATA_LOADER_DATABASE=localhost

## Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_TOKEN_URL=http://keycloak:8080/realms/localhost/protocol/openid-connect/token
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DEFAULT_USER=demo
KEYCLOAK_DEFAULT_USER_PASSWORD=demo
KEYCLOAK_DEFAULT_USER_FIRST_NAME=demo
KEYCLOAK_DEFAULT_USER_LAST_NAME=demo
KEYCLOAK_DEFAULT_USER_EMAIL=demo@demo.com

## OPA
OPA_URL=http://opa:8181/v1/data/wks/authz/allow

## CASE PORTAL
## For the MINIMAL (`core`) backend, run the portal via `yarn start` with
## REACT_APP_AUTH_MODE=dev-token and REACT_APP_AUTH_URL=http://localhost:8081/dev-auth
## (see apps/react/case-portal/.env-sample). The dockerized portal below is the
## Keycloak (full-stack) variant.
REACT_APP_KEYCLOAK_URL=http://localhost:8082
REACT_APP_API_URL=http://localhost:8081
REACT_APP_STORAGE_URL=http://localhost:8085
REACT_APP_WEBSOCKETS_ENABLED=false
REACT_APP_WEBSOCKETS_URL=ws://localhost:8484
REACT_APP_WEBSOCKETS_CASE_CREATED=case-create
REACT_APP_WEBSOCKETS_HUMAN_TASK_CREATED=human-task-create
REACT_APP_NOVU_ENABLED=false
REACT_APP_NOVU_PUBLISHER_API_URL=http://localhost:3002

## CASE REST API
WKS_CASE_API_URL=http://case-engine-rest-api:8081

## C7 EXTERNAL TASKS
DISABLE_BACKOFF_STRATEGY=false

## MINIO
MINIO_HOST_INTERNAL=minio
MINIO_HOST_EXTERNAL=localhost
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD='#minio00#'

## Kafka
KAFKA_URL=kafka:9093
KAFKA_TOPIC_CASE_CREATE=case-create
KAFKA_TOPIC_CASE_EMAIL_OUTBOUND=case-email-outbound
KAFKA_TOPIC_CREATE_HUMAN_TASK=human-task-create

## Novu
NOVU_ENABLED=false
NOVU_TRIGGER_URL=https://api.novu.co/v1/events/trigger
NOVU_APP_ID=
NOVU_API_KEY=
NOVU_LOG_LEVEL=info
NOVU_PUBLISHER_API_URL=http://localhost:3002

## WEBSOCKET
WEBSOCKET_ENABLED=false
WEBSOCKET_URL=ws://localhost:8484
WEBSOCKET_LOG_LEVEL=info

## EMAIL-SENDER
EMAIL_SENDER_LOG_LEVEL=info
MAIL_TO_CASE_JWT_TOKEN_CLIENT_ID=wks-email-to-case
MAIL_TO_CASE_JWT_TOKEN_CLIENT_SECRET=replaceme
MAIL_TO_CASE_JWT_TOKEN_GRANT_TYPE=client_credentials

## Camunda 7
CAMUNDA_BASE_URL=http://camunda:8080/engine-rest
CAMUNDA_USERNAME=demo
CAMUNDA_PASSWORD=demo
CAMUNDA_DOCKER_IMAGE=camunda/camunda-bpm-platform
CAMUNDA7_VERSION=run-7.24.0
